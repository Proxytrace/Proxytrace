# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for @llm specs (ingestion, test-run).
# Without this, those specs are skipped and the rest still pass.
OPENAI_API_KEY=sk-...

# Upstream endpoint for @llm specs.
# Defaults to the real OpenAI API.
# Set this to any OpenAI-compatible endpoint (Ollama, LM Studio, Azure, etc.).
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use for @llm specs. Must be served by the endpoint above.
# Defaults to gpt-4o-mini.
LLM_MODEL=gpt-4o-mini
