# Kiosk showcase stack — LLM endpoint configuration
# Copy to .env and fill in your values, then run:
#   docker compose -f docker-compose.kiosk.yml up --build
#
# Without this file the stack starts in read-only demo mode: the kiosk API and frontend
# boot normally, but the OpenAI proxy returns 503 and sample-client idles without a key.

# ── Required for live demo mode ──────────────────────────────────────────────

# LLM provider base URL (OpenAI-compatible, e.g. https://api.openai.com/v1)
KIOSK_LLM_BASE_URL=https://api.openai.com/v1

# Provider API key
KIOSK_LLM_API_KEY=sk-...

# Model name — feeds BOTH the api service (Kiosk:Endpoint:Model) AND the sample-client (MODEL).
# A single variable here prevents the endpoint and chat client from drifting to different models.
KIOSK_LLM_MODEL=gpt-4o-mini

# ── Optional overrides ────────────────────────────────────────────────────────

# Provider kind: OpenAi | OpenAiCompatible (default: OpenAi)
# KIOSK_LLM_KIND=OpenAi

# Demo API key injected into both the api service and sample-client (default: pk-kiosk-demo).
# Override only if you need a custom key; both sides must still match.
# KIOSK_DEMO_API_KEY=pk-kiosk-demo
