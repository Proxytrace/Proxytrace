{
  "ConnectionStrings": {
    "Default": "Data Source=trsr.db"
  },
  "ModelProvider": {
    "UpstreamBaseUrl": "https://api.openai.com"
  },
  "Self": {
    "BaseUrl": "http://localhost:5000"
  },
  "Frontend": {
    "AllowedOrigin": "http://localhost:4201"
  },
  "TestRunner": {
    "MaxDegreeOfParallelism": 2
  },
  "Search": {
    "IndexPath": "searchindex",
    "TraceRetentionDays": 30,
    "PrunerIntervalHours": 6,
    "HitsPerKind": 5,
    "SnippetMaxChars": 160
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
