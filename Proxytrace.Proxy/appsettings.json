{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=proxytrace;Username=proxytrace;Password=proxytrace"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "Provider": "Redis",
    "Stream": "proxytrace:ingest",
    "ConsumerGroup": "proxytrace-app"
  },
  "BlockingRuleCache": {
    "TtlSeconds": 30
  },
  "Licensing": {
    "StoredLicensePollSeconds": 300
  },
  "Kiosk": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
