{
  "ConnectionStrings": {
    "Default": "Data Source=proxytrace.db"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "Stream": "proxytrace:ingest",
    "ConsumerGroup": "proxytrace-app"
  },
  "ApiKeyCache": {
    "TtlSeconds": 30
  },
  "Cors": {
    "FrontendOrigin": "http://localhost:4201"
  },
  "Kiosk": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
