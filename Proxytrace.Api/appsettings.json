{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=proxytrace;Username=proxytrace;Password=proxytrace"
  },
  "ModelProvider": {
    "UpstreamBaseUrl": "https://api.openai.com"
  },
  "Pricing": {
    "LiteLlmFeedUrl": "https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json",
    "FxApiUrl": "https://api.frankfurter.app/latest",
    "RefreshIntervalHours": 1
  },
  "Kiosk": {
    "Enabled": true
  },
  "Updates": {
    "Enabled": true,
    "ManifestUrl": "https://api.github.com/repos/Proxytrace/Proxytrace/releases/latest",
    "CheckIntervalHours": 24
  },
  "Self": {
    "BaseUrl": "http://localhost:5001"
  },
  "Proxy": {
    "PublicBaseUrl": "http://localhost:5002"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "Provider": "InProcess",
    "Stream": "proxytrace:ingest",
    "ConsumerGroup": "proxytrace-app"
  },
  "Frontend": {
    "AllowedOrigin": "http://localhost:4201"
  },
  "AgentCallCleanup": {
    "RetentionDurationDays": 30,
    "CleanupIntervalHours": 1
  },
  "ErrorLogCleanup": {
    "RetentionDurationDays": 14,
    "CleanupIntervalHours": 6,
    "MaxRetained": 10000
  },
  "AuditLogCleanup": {
    "RetentionDurationDays": 365,
    "CleanupIntervalHours": 24
  },
  "Authentication": {
    "Oidc": {
      "Authority": "",
      "Audience": "proxytrace-api",
      "RequireHttpsMetadata": true,
      "EmailClaimType": "email",
      "NameClaimType": "name"
    },
    "Local": {
      "SigningKey": ""
    },
    "EmergencyLogResetLink": false
  },
  "TestRunner": {
    "MaxDegreeOfParallelism": 2
  },
  "Licensing": {
    "CheckIntervalHours": 24,
    "OfflineGracePeriodDays": 7
  },
  "Search": {
    "IndexPath": "searchindex",
    "TraceRetentionDays": 30,
    "PrunerIntervalHours": 6,
    "HitsPerKind": 5,
    "SnippetMaxChars": 160,
    "Requests": {
      "MinQueryLength": 2,
      "MaxQueryLength": 200,
      "MinSnippetLength": 20,
      "MaxSnippetLength": 1000
    }
  },
  "Statistics": {
    "DefaultRecentTraceCount": 6,
    "MaxRecentTraceCount": 50,
    "DefaultAgentLimit": 10,
    "MaxAgentLimit": 100,
    "DashboardCacheTtlSeconds": 10
  },
  "SecurityHeaders": {
    "ContentSecurityPolicy": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https:; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'",
    "DocsContentSecurityPolicy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https:; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
