{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=proxytrace;Username=proxytrace;Password=proxytrace"
  },
  "ModelProvider": {
    "UpstreamBaseUrl": "https://api.openai.com"
  },
  "Kiosk": {
    "Enabled": true
  },
  "Self": {
    "BaseUrl": "http://localhost:5000"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "Provider": "Redis",
    "Stream": "proxytrace:ingest",
    "ConsumerGroup": "proxytrace-app"
  },
  "Frontend": {
    "AllowedOrigin": "http://localhost:4201"
  },
  "AgentCallCleanup": {
    "RetentionDurationDays": 30,
    "CleanupIntervalHours": 1
  },
  "Authentication": {
    "Oidc": {
      "Authority": "",
      "Audience": "proxytrace-api",
      "RequireHttpsMetadata": true,
      "EmailClaimType": "email",
      "NameClaimType": "name"
    },
    "Local": {
      "SigningKey": ""
    }
  },
  "TestRunner": {
    "MaxDegreeOfParallelism": 2
  },
  "Licensing": {
    "CheckIntervalHours": 24,
    "OfflineGracePeriodDays": 7
  },
  "Search": {
    "IndexPath": "searchindex",
    "TraceRetentionDays": 30,
    "PrunerIntervalHours": 6,
    "HitsPerKind": 5,
    "SnippetMaxChars": 160
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
