FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
USER root
# Pre-create the writable runtime data dirs (Lucene search index, plus the appdata dir
# that holds generated secrets / the session signing key / the license offline-grace cache)
# and hand /app to the non-root app user. A named volume mounted at /app/searchindex or
# /app/data inherits this ownership on first use (an empty named volume copies the image
# dir's owner); bind mounts must be made writable by $APP_UID on the host.
RUN mkdir -p /app/searchindex /app/data && chown -R $APP_UID:$APP_UID /app
USER $APP_UID
WORKDIR /app
EXPOSE 8080
EXPOSE 8081

# --platform=$BUILDPLATFORM: the SDK always runs natively on the build host and
# cross-compiles for $TARGETARCH (amd64/arm64), so multi-arch release builds avoid
# running the compiler under QEMU emulation. Only the runtime stages are per-arch.
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG TARGETARCH
ARG BUILD_CONFIGURATION=Release
# Release version injected by the release workflow (-p:Version); see Directory.Build.props.
ARG APP_VERSION=0.0.0-dev
# Compile-time license public-key override (comma-separated base64 SPKI). Empty ⇒ embedded
# production key. The dev/e2e/perf composes pass the test key; official images pass nothing.
ARG LICENSE_PUBLIC_KEY=
WORKDIR /src
COPY ["Proxytrace.Api/Proxytrace.Api.csproj", "Proxytrace.Api/"]
COPY ["Proxytrace.Application/Proxytrace.Application.csproj", "Proxytrace.Application/"]
COPY ["Proxytrace.Common/Proxytrace.Common.csproj", "Proxytrace.Common/"]
COPY ["Proxytrace.Domain/Proxytrace.Domain.csproj", "Proxytrace.Domain/"]
COPY ["Proxytrace.Infrastructure/Proxytrace.Infrastructure.csproj", "Proxytrace.Infrastructure/"]
COPY ["Proxytrace.Messaging/Proxytrace.Messaging.csproj", "Proxytrace.Messaging/"]
COPY ["Proxytrace.Serialization/Proxytrace.Serialization.csproj", "Proxytrace.Serialization/"]
COPY ["Proxytrace.Storage/Proxytrace.Storage.csproj", "Proxytrace.Storage/"]
RUN dotnet restore "Proxytrace.Api/Proxytrace.Api.csproj" -a $TARGETARCH
COPY . .
WORKDIR "/src/Proxytrace.Api"
# SkipManualBuild: the SDK image has no npm, and in the Docker setup the VitePress manual
# is served by the nginx frontend, not the API's wwwroot. So skip the manual build here.
RUN dotnet build "./Proxytrace.Api.csproj" -a $TARGETARCH -c $BUILD_CONFIGURATION -o /app/build /p:SkipManualBuild=true -p:Version=$APP_VERSION "-p:LicensePublicKey=$LICENSE_PUBLIC_KEY"

FROM build AS publish
ARG TARGETARCH
ARG BUILD_CONFIGURATION=Release
ARG APP_VERSION=0.0.0-dev
ARG LICENSE_PUBLIC_KEY=
# DebugType=none: ship no PDBs — they carry line-accurate symbols and a SourceLink map
# pointing at the source repo + commit SHA (needless bloat). Trade-off: production stack traces lose
# file/line info (exception messages and frames remain).
RUN dotnet publish "./Proxytrace.Api.csproj" -a $TARGETARCH -c $BUILD_CONFIGURATION -o /app/publish /p:UseAppHost=false /p:SkipManualBuild=true -p:Version=$APP_VERSION -p:DebugType=none "-p:LicensePublicKey=$LICENSE_PUBLIC_KEY"

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "Proxytrace.Api.dll"]
