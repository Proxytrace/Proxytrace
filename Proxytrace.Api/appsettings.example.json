{
  "ConnectionStrings": {
    "Default": "Data Source=proxytrace.db",
    "_Comments": {
      "SQLite": "Data Source=proxytrace.db",
      "SQLiteInMemory": "Data Source=:memory:",
      "SqlServer": "Server=localhost;Database=Proxytrace;Trusted_Connection=True;TrustServerCertificate=True;",
      "PostgreSQL": "Host=localhost;Database=Proxytrace;Username=postgres;Password=yourpassword"
    }
  },
  "ModelProvider": {
    "UpstreamBaseUrl": "https://api.openai.com"
  },
  "Self": {
    "BaseUrl": "http://localhost:5000"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Messaging": {
    "_Comment": "Provider=Redis for the proxy/app split; InProcess for single-process runs.",
    "Provider": "Redis",
    "Stream": "proxytrace:ingest",
    "ConsumerGroup": "proxytrace-app"
  },
  "Frontend": {
    "AllowedOrigin": "http://localhost:4200"
  },
  "TestRunner": {
    "MaxDegreeOfParallelism": 2
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

