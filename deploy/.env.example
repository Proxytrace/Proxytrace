# Proxytrace deployment configuration — every setting is OPTIONAL.
# `docker compose up -d` works without any .env file. Copy this file to .env
# only to override defaults:
#   cp .env.example .env

# Password for the bundled Postgres database. Defaults to "proxytrace"; the
# database is internal-only (no host port is published), but setting your own
# password is recommended for production.
# Generate one:  openssl rand -hex 24
#POSTGRES_PASSWORD=

# Key used to sign login session tokens (JWT). Minimum 32 characters. When
# unset, a key is generated on first start and persisted in the appdata
# volume — sessions survive restarts and upgrades either way.
# Generate one:  openssl rand -base64 48
#PROXYTRACE_SIGNING_KEY=

# Your license key (JWT). Leave empty to run the Free tier. A license can
# also be entered in the setup wizard or later under Settings → License —
# a key set there is stored in the database and overrides this variable.
#PROXYTRACE_LICENSE=

# The public URL your users open in the browser (scheme + host + port).
# Used for CORS and self-referencing links. Update when serving behind a
# reverse proxy or a real domain, e.g. https://proxytrace.example.com
#PROXYTRACE_PUBLIC_URL=http://localhost:5101

# Host ports.
# FRONTEND_PORT: the web UI.
# PROXY_PORT: the OpenAI-compatible ingestion proxy — point your agents'
#             OpenAI base URL at http://<host>:${PROXY_PORT}/openai/v1
#FRONTEND_PORT=5101
#PROXY_PORT=5102

# Release to run. The downloaded release artifact pins this to its version;
# pin it explicitly when running from the repository.
#PROXYTRACE_VERSION=latest
