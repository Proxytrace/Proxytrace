{
  "name": "proxytrace-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen:docs": "node scripts/docs-index/generate.mjs",
    "predev": "npm run gen:docs",
    "dev": "concurrently -n vite,docs -c green,cyan \"vite\" \"npm --prefix ../manual run docs:dev\"",
    "dev:app": "vite",
    "prebuild": "npm run gen:docs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pretest": "npm run gen:docs",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.67",
    "@assistant-ui/react": "^0.14.12",
    "@assistant-ui/react-ai-sdk": "^1.3.31",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "ai": "^6.0.193",
    "dompurify": "^3.4.5",
    "oidc-client-ts": "^3.5.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-oidc-context": "^3.3.1",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.9"
  }
}
