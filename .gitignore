# Build outputs
bin/
obj/
/packages/
/_ReSharper.Caches/
TestResults/
BenchmarkDotNet.Artifacts/

# Dependencies
node_modules/

# Local IDE / editor / agent tooling — never commit
.idea/
.vs/
.vscode/
.devcontainer/
.superpowers/
docs/superpowers/
riderModule.iml
*.DotSettings
*.DotSettings.user
.DS_Store

# Development plans / scratch notes
REFACTORING-TODO.md
*-PLAN.md
*-TODO.md

# Claude Code: skills, hooks, and settings.json are tracked; local state is not
.claude/worktrees/
.claude/skills/*-workspace/

# Development configuration files
**/appsettings.development.json
**/appsettings.local.json
*.local.json
**/__pycache__/*
sample-client/.env
# Docker Compose reads a repo-root .env automatically, so one exists on most dev machines and
# holds real provider credentials. It was not ignored — a `git add -A` would have committed it.
/.env

# Local databases
**/*.db-*
Proxytrace.Api/proxytrace.db

# Lucene full-text search index
searchindex/
**/searchindex/

# Generated web root: SPA build + VitePress manual (Proxytrace.Api/wwwroot/docs) are
# produced at Release build time and must not be committed.
Proxytrace.Api/wwwroot/

# E2E test artifacts
e2e/.auth/storageState.json
e2e/.auth/licensing-state.json
e2e/playwright-report/
e2e/test-results/
e2e/.env
# Docker Compose logs captured on e2e failure (CI: the `e2e-stack-logs` artifact)
stack-logs/

# Performance suite outputs (generated by perf/run.sh)
perf/results/
