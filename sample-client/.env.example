# Your Trsr API key — authenticates this client with the Trsr proxy.
# The proxy uses the model provider's API key (configured in Trsr) when forwarding to OpenAI.
TRSR_API_KEY=trsr-...

# Trsr proxy base URL. Replace {org} and {project} with your values.
# The proxy forwards requests to OpenAI and captures every interaction.
# To bypass Trsr and call OpenAI directly, set this to: https://api.openai.com/v1
TRSR_BASE_URL=http://localhost:5000/openai/v1

# Model to use
MODEL=gpt-5.1

# System prompt for the chatbot
SYSTEM_PROMPT=You are a helpful assistant.

# Port for this sample server
PORT=3000
